# Environment Configuration for Base App
# Copy this file to .env and fill in your values

# App Environment (development, staging, production)
EXPO_PUBLIC_ENVIRONMENT=development

# API Configuration
# Override the default API URL for any environment
# Generic override used for all envs if set:
# EXPO_PUBLIC_API_URL=https://your-custom-api-url.com

# Environment-specific overrides (take precedence over the generic var):
# EXPO_PUBLIC_API_URL_DEVELOPMENT=http://127.0.0.1:8000
# EXPO_PUBLIC_API_URL_STAGING=https://your-staging-api.example.com
# EXPO_PUBLIC_API_URL_PRODUCTION=https://eguchi-api-production.up.railway.app

# Auth0 Configuration
EXPO_PUBLIC_AUTH0_DOMAIN=dev-dv5sxg3q0hnih5mb.us.auth0.com
EXPO_PUBLIC_AUTH0_CLIENT_ID=anmRxoN5x2uWiXdjAyXe33kW4d8N81Vj
EXPO_PUBLIC_AUTH0_AUDIENCE=https://eguchi-api-production.up.railway.app/api
EXPO_PUBLIC_URL_SCHEME=eguchieartrainer

# Default API URLs by Environment:
# development: http://127.0.0.1:8000
# staging: https://baseapp-staging.up.railway.app
# production: https://eguchi-api-production.up.railway.app
