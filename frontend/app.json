{
  "expo": {
    "name": "Eguchi Ear Trainer",
    "slug": "eguchi-ear-trainer",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/eguchi/ui/app-icon.png",
    "scheme": "eguchieartrainer",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": ["assets/audio/**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.eguchi.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/eguchi/ui/app-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.eguchi.app",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/eguchi/ui/app-icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://eguchi-api-production.up.railway.app"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/eguchi/ui/app-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5a909b9d-6999-431c-ab81-a53187d7575a"
      }
    },
    "owner": "adrienle"
  }
}
